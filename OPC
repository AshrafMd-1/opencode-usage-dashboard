#!/usr/bin/env bash
set -euo pipefail

if ! command -v node >/dev/null 2>&1; then
  echo "OPC requires Node.js 18+ (node not found in PATH)." >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OPC_SCRIPT_DIR="$SCRIPT_DIR" node - "$@" <<'NODE'
const fs = require("node:fs");
const os = require("node:os");
const path = require("node:path");
const { pathToFileURL } = require("node:url");

const argv = process.argv.slice(2);
const opts = {
  latest: 0,
  json: false,
  verbose: false,
  utc: false,
  help: false,
  refresh: false,
  savePages: false,
  start: null,
  end: null,
};

function readOptionValue(name, i) {
  const value = argv[i + 1];
  if (!value || value.startsWith("--")) die(`${name} requires a value\nRun OPC --help`);
  return value;
}

function parsePositiveInt(value, name) {
  if (!/^\d+$/.test(String(value || ""))) die(`${name} must be a positive whole number`);
  const n = Number(value);
  if (!Number.isSafeInteger(n) || n <= 0) die(`${name} must be a positive whole number`);
  return n;
}

function parseDateOption(value, name) {
  const m = String(value || "").match(/^(\d{2})-(\d{2})-(\d{4})$/);
  if (!m) die(`${name} must use DD-MM-YYYY format`);
  const day = Number(m[1]);
  const month = Number(m[2]);
  const year = Number(m[3]);
  const d = new Date(year, month - 1, day);
  if (d.getFullYear() !== year || d.getMonth() !== month - 1 || d.getDate() !== day) die(`${name} is not a valid date`);
  return { day, month, year, value };
}

function dateBoundary(info, endOfDay = false) {
  if (!info) return null;
  const h = endOfDay ? 23 : 0;
  const m = endOfDay ? 59 : 0;
  const s = endOfDay ? 59 : 0;
  const ms = endOfDay ? 999 : 0;
  return opts.utc
    ? new Date(Date.UTC(info.year, info.month - 1, info.day, h, m, s, ms))
    : new Date(info.year, info.month - 1, info.day, h, m, s, ms);
}

for (let i = 0; i < argv.length; i++) {
  const a = argv[i];
  if (["-h", "--help", "help"].includes(a)) opts.help = true;
  else if (["--by-day", "--day", "day", "days"].includes(a)) continue; // Kept as a hidden no-op for old commands; by-day is now always shown.
  else if (a === "--latest") opts.latest = parsePositiveInt(readOptionValue("--latest", i++), "--latest");
  else if (a.startsWith("--latest=")) opts.latest = parsePositiveInt(a.split("=")[1], "--latest");
  else if (a === "--start") opts.start = parseDateOption(readOptionValue("--start", i++), "--start");
  else if (a.startsWith("--start=")) opts.start = parseDateOption(a.split("=")[1], "--start");
  else if (a === "--end") opts.end = parseDateOption(readOptionValue("--end", i++), "--end");
  else if (a.startsWith("--end=")) opts.end = parseDateOption(a.split("=")[1], "--end");
  else if (a === "--json") opts.json = true;
  else if (["-v", "--verbose"].includes(a)) opts.verbose = true;
  else if (a === "--utc") opts.utc = true;
  else if (["--refresh", "--full"].includes(a)) opts.refresh = true;
  else if (["--save-pages", "--debug-pages"].includes(a)) opts.savePages = true;
  else die(`Unknown option: ${a}\nRun OPC --help`);
}

if (opts.start && opts.end && dateBoundary(opts.start).getTime() > dateBoundary(opts.end).getTime()) die("--start must be on or before --end");

if (opts.help) {
  console.log(`OPC - OpenCode usage summary with local pagination cache

Usage:
  OPC                              Show quota/reset, total spend, spend periods, by-model table, and by-day table
  OPC --latest N                   Show latest N raw usage requests (example: OPC --latest 20)
  OPC --start DD-MM-YYYY           Include requests from this date onward
  OPC --end DD-MM-YYYY             Include requests up to and including this date
  OPC --start DD-MM-YYYY --end DD-MM-YYYY
                                   Include requests between both dates, inclusive
  OPC --refresh                    Ignore cache and refetch every usage page
  OPC --save-pages                 Debug only: save fetched page JSON snapshots under data/pages/
  OPC --json                       Print machine-readable summary JSON
  OPC --utc                        Group/display dates in UTC instead of local time

Config:
  OPC reads .env next to this script first, then normal environment variables.
  Required in .env:
    OPENCODE_USAGE_URL=https://opencode.ai/workspace/<id>/usage
    OPENCODE_AUTH=<raw auth cookie value, or full Cookie header>
  Optional:
    OPC_DATA_DIR=./data

Cache:
  Stores only merged usage in data/usage.json and metadata in data/meta.json.
  Later runs fetch pages only until 5 sequential cached request fingerprints overlap.
  Page snapshots are not written unless --save-pages is passed.`);
  process.exit(0);
}

function die(msg) {
  console.error(msg);
  process.exit(1);
}

const scriptDir = process.env.OPC_SCRIPT_DIR || process.cwd();

function loadDotEnv(file) {
  try {
    if (!fs.existsSync(file)) return;
    const lines = fs.readFileSync(file, "utf8").split(/\r?\n/);
    for (const line of lines) {
      const trimmed = line.trim();
      if (!trimmed || trimmed.startsWith("#")) continue;
      const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\s*=\s*(.*)$/);
      if (!m) continue;
      const key = m[1];
      let value = m[2].trim();
      if ((value.startsWith('"') && value.endsWith('"')) || (value.startsWith("'") && value.endsWith("'"))) {
        value = value.slice(1, -1);
      }
      // Shell/env wins; .env fills missing values.
      if (process.env[key] == null || process.env[key] === "") process.env[key] = value;
    }
  } catch (e) {
    die(`Could not read .env: ${e?.message || e}`);
  }
}

loadDotEnv(path.join(scriptDir, ".env"));

const configuredDataDir = process.env.OPC_DATA_DIR || path.join(scriptDir, "data");
const dataDir = path.isAbsolute(configuredDataDir) ? configuredDataDir : path.resolve(scriptDir, configuredDataDir);
const usageStoreFile = path.join(dataDir, "usage.json");
const metaFile = path.join(dataDir, "meta.json");
const pagesRoot = path.join(dataDir, "pages");

function readGoConfig() {
  const home = os.homedir();
  const candidates = [
    path.join(home, ".config", "opencode", "opencode-quota", "opencode-go.json"),
    path.join(home, "Library", "Application Support", "opencode", "opencode-quota", "opencode-go.json"),
  ];
  for (const file of candidates) {
    try {
      if (!fs.existsSync(file)) continue;
      const data = JSON.parse(fs.readFileSync(file, "utf8"));
      const workspaceId = typeof data.workspaceId === "string" ? data.workspaceId.trim() : "";
      const authCookie = typeof data.authCookie === "string" ? data.authCookie.trim() : "";
      if (workspaceId || authCookie) return { workspaceId, authCookie, file };
    } catch {}
  }
  return null;
}

const cfg = readGoConfig();
let usageUrl = process.env.OPENCODE_USAGE_URL || process.env.OPC_URL || process.env.URL || "";
let auth = process.env.OPENCODE_AUTH || process.env.OPC_AUTH || process.env.auth || process.env.AUTH || process.env.OPENCODE_GO_AUTH_COOKIE || "";

if (!usageUrl && cfg?.workspaceId) usageUrl = `https://opencode.ai/workspace/${encodeURIComponent(cfg.workspaceId)}/usage`;
if (!auth && cfg?.authCookie) auth = cfg.authCookie;

if (!usageUrl) die("Missing OPENCODE_USAGE_URL (or OPC_URL/URL), and no opencode-go config workspaceId was found.");
if (!auth) die("Missing OPENCODE_AUTH (or OPC_AUTH/auth), and no opencode-go config authCookie was found.");

let usageURLObj;
try { usageURLObj = new URL(usageUrl); } catch { die(`Invalid usage URL: ${usageUrl}`); }
const workspaceMatch = usageURLObj.pathname.match(/\/workspace\/([^/]+)/);
if (!workspaceMatch) die(`Could not find workspace id in URL: ${usageUrl}`);
const workspaceId = decodeURIComponent(workspaceMatch[1]);
const origin = usageURLObj.origin;
const goUrl = new URL(`/workspace/${encodeURIComponent(workspaceId)}/go`, origin).toString();
const cookieHeader = auth.includes("=") ? auth : `auth=${auth}`;

function headers(accept = "text/html") {
  return {
    "User-Agent": "Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7) OPC/1.0",
    "Accept": accept,
    "Cookie": cookieHeader,
    "Referer": usageUrl,
  };
}

async function fetchText(url, accept = "text/html") {
  const res = await fetch(url, { headers: headers(accept) });
  if (!res.ok) throw new Error(`HTTP ${res.status} fetching ${url}`);
  return await res.text();
}

function pick(obj, ...names) {
  for (const n of names) if (obj && obj[n] != null) return obj[n];
  return undefined;
}

function parseQuota(html) {
  const defs = [
    ["S", "rolling", "Rolling"],
    ["W", "weekly", "Weekly"],
    ["M", "monthly", "Monthly"],
  ];
  const out = [];
  for (const [short, key, label] of defs) {
    const re = new RegExp(`${key}Usage:\\$R\\[\\d+\\]=\\{([^}]*)\\}`);
    const m = html.match(re);
    if (!m) continue;
    const body = m[1];
    const pct = Number(pick(body.match(/usagePercent:([0-9.]+)/), 1));
    const reset = Number(pick(body.match(/resetInSec:([0-9.]+)/), 1));
    if (!Number.isFinite(pct) || !Number.isFinite(reset)) continue;
    out.push({ short, key, label, usagePercent: pct, resetInSec: reset, resetAt: new Date(Date.now() + reset * 1000) });
  }
  return out;
}

async function discoverRuntimeAndUsageId(html) {
  const tmp = fs.mkdtempSync(path.join(os.tmpdir(), "opc-opencode-"));
  fs.writeFileSync(path.join(tmp, "package.json"), JSON.stringify({ type: "module" }));
  const assetPaths = [...new Set([...html.matchAll(/(?:src|href)="([^"]+\.js(?:\?[^"]*)?)"/g)].map(m => m[1]))];
  if (assetPaths.length === 0) throw new Error("No JS assets found in usage page");

  const files = [];
  await Promise.all(assetPaths.map(async (asset) => {
    const url = new URL(asset, origin).toString();
    const file = path.join(tmp, path.basename(asset.split("?")[0]));
    const code = await fetchText(url, "application/javascript,*/*");
    fs.writeFileSync(file, code);
    files.push(file);
  }));

  let usageFile = "";
  let usageCode = "";
  for (const file of files) {
    const code = fs.readFileSync(file, "utf8");
    if (code.includes("usage.list")) {
      usageFile = file;
      usageCode = code;
      break;
    }
  }
  if (!usageFile) throw new Error("Could not find usage.list client bundle");

  const idx = usageCode.indexOf("usage.list");
  const before = usageCode.slice(Math.max(0, idx - 2000), idx);
  const matches = [...before.matchAll(/createServerReference\("([^"]+)"\)/g)];
  const serverId = matches.at(-1)?.[1];
  if (!serverId) throw new Error("Could not discover usage.list server function id");

  let runtimeFile = "";
  const importMatch = usageCode.match(/from "\.\/([^"]*server-runtime[^"]*\.js)"/);
  if (importMatch) runtimeFile = path.join(tmp, importMatch[1]);
  if (!runtimeFile || !fs.existsSync(runtimeFile)) {
    runtimeFile = files.find(f => fs.readFileSync(f, "utf8").includes("function createServerReference")) || "";
  }
  if (!runtimeFile) throw new Error("Could not find server-runtime bundle");
  return { runtimeFile, serverId };
}

function ensureDataDirs() {
  fs.mkdirSync(dataDir, { recursive: true });
}

function readCachedUsage() {
  try {
    if (!fs.existsSync(usageStoreFile)) return [];
    const parsed = JSON.parse(fs.readFileSync(usageStoreFile, "utf8"));
    return Array.isArray(parsed) ? parsed : [];
  } catch {
    return [];
  }
}

function sortUsage(rows) {
  return rows.slice().sort((a, b) => new Date(b.timeCreated).getTime() - new Date(a.timeCreated).getTime());
}

function usageFingerprint(r) {
  // OpenCode currently returns an id (usg_...), but don't rely on only that.
  // Include the stable request fields too, so the 5-row overlap check is a
  // real sequential usage match: timestamp + model/provider + token counts + cost.
  const isoTime = r?.timeCreated ? new Date(r.timeCreated).toISOString() : "";
  return JSON.stringify([
    r?.id || "",
    r?.workspaceID || workspaceId,
    isoTime,
    r?.model || "",
    r?.provider || "",
    num(r?.inputTokens),
    num(r?.outputTokens),
    num(r?.reasoningTokens),
    num(r?.cacheReadTokens),
    num(r?.cacheWrite5mTokens),
    num(r?.cacheWrite1hTokens),
    num(r?.cost),
    r?.keyID || "",
    r?.sessionID || "",
    r?.enrichment?.plan || "",
  ]);
}

function dedupeUsage(rows) {
  const seen = new Set();
  const out = [];
  for (const r of sortUsage(rows)) {
    const key = usageFingerprint(r);
    if (seen.has(key)) continue;
    seen.add(key);
    out.push(r);
  }
  return out;
}

function saveUsage(rows, meta) {
  ensureDataDirs();
  const clean = dedupeUsage(rows);
  fs.writeFileSync(usageStoreFile, JSON.stringify(clean, null, 2));
  fs.writeFileSync(metaFile, JSON.stringify({ ...meta, workspaceId, totalRequests: clean.length, updatedAt: new Date().toISOString() }, null, 2));
  return clean;
}

function createPageSnapshotRun() {
  if (!opts.savePages) return null;
  ensureDataDirs();
  fs.mkdirSync(pagesRoot, { recursive: true });
  const runId = new Date().toISOString().replace(/[:.]/g, "-");
  const dir = path.join(pagesRoot, runId);
  fs.mkdirSync(dir, { recursive: true });
  return { runId, dir };
}

function savePageSnapshot(run, page, rows) {
  if (!run) return;
  const file = path.join(run.dir, `page-${String(page).padStart(4, "0")}.json`);
  fs.writeFileSync(file, JSON.stringify({ workspaceId, page, fetchedAt: new Date().toISOString(), requests: rows }, null, 2));
}

function findSequentialOverlap(fetchedRows, cachedRows, minRun = 5) {
  if (cachedRows.length === 0 || fetchedRows.length === 0) return null;
  const cachedKeys = cachedRows.map(usageFingerprint);
  const pos = new Map(cachedKeys.map((key, i) => [key, i]));
  const fetchedKeys = fetchedRows.map(usageFingerprint);
  const needed = Math.min(minRun, cachedKeys.length);
  for (let i = 0; i < fetchedKeys.length; i++) {
    const key = fetchedKeys[i];
    if (!pos.has(key)) continue;
    const j = pos.get(key);
    let n = 0;
    while (
      i + n < fetchedKeys.length &&
      j + n < cachedKeys.length &&
      fetchedKeys[i + n] === cachedKeys[j + n]
    ) n++;
    if (n >= needed) return { fetchedIndex: i, cachedIndex: j, count: n };
  }
  return null;
}

async function createUsageFetcher(html) {
  const { runtimeFile, serverId } = await discoverRuntimeAndUsageId(html);
  globalThis.self = globalThis;
  const runtime = await import(pathToFileURL(runtimeFile).href);
  const createServerReference = runtime.a || runtime.createServerReference;
  if (!createServerReference) throw new Error("server-runtime did not export createServerReference");

  const realFetch = globalThis.fetch.bind(globalThis);
  globalThis.fetch = (input, init = {}) => {
    let url = typeof input === "string" ? input : input.url;
    if (url.startsWith("/")) url = origin + url;
    init.headers = { ...(init.headers || {}), ...headers("*/*") };
    return realFetch(url, init);
  };

  const getUsageInfo = createServerReference(serverId);
  return async (page) => {
    const rows = await getUsageInfo(workspaceId, page);
    if (!Array.isArray(rows)) throw new Error(`Unexpected usage response for page ${page}`);
    return rows;
  };
}

async function fetchUsageWithCache(html) {
  const cached = opts.refresh ? [] : dedupeUsage(readCachedUsage());
  const fetchPage = await createUsageFetcher(html);
  const run = createPageSnapshotRun();
  let apiPagesFetched = 0;
  const fetched = [];
  let newRequests = [];
  let overlap = null;
  let fullRefresh = opts.refresh || cached.length === 0;

  for (let page = 0; ; page++) {
    const rows = await fetchPage(page);
    apiPagesFetched += 1;
    savePageSnapshot(run, page, rows);
    fetched.push(...rows);
    if (opts.verbose) console.error(`page ${page}: ${rows.length} requests`);

    if (!fullRefresh) {
      overlap = findSequentialOverlap(rows, cached, 5);
      if (overlap) {
        const earlierPages = fetched.slice(0, fetched.length - rows.length);
        newRequests = earlierPages.concat(rows.slice(0, overlap.fetchedIndex));
        break;
      }
    }

    if (rows.length < 50) break;
    if (page > 5000) throw new Error("Too many pages; stopping to avoid infinite pagination");
  }

  let merged;
  if (fullRefresh || !overlap) {
    merged = fetched;
    const cachedKeys = new Set(cached.map(usageFingerprint));
    newRequests = cached.length ? fetched.filter(r => !cachedKeys.has(usageFingerprint(r))) : fetched;
  } else {
    merged = newRequests.concat(cached);
  }

  const cacheMeta = {
    file: usageStoreFile,
    pageSnapshotDir: run?.dir || null,
    apiPagesFetched,
    newRequests: dedupeUsage(newRequests).length,
    cacheRequestsBefore: cached.length,
    refresh: opts.refresh,
    savePages: opts.savePages,
    overlap,
  };
  const rows = saveUsage(merged, { cacheFile: usageStoreFile, ...cacheMeta });

  return { rows, cache: cacheMeta };
}

function num(x) { return Number(x || 0); }
function rowCost(r) { return num(r.cost) / 1e8; }
function totalInput(r) { return num(r.inputTokens) + num(r.cacheReadTokens) + num(r.cacheWrite5mTokens) + num(r.cacheWrite1hTokens); }
function localDateKey(d) {
  if (opts.utc) return d.toISOString().slice(0, 10);
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  return `${y}-${m}-${day}`;
}
function fmtDateTime(d) {
  if (opts.utc) return d.toISOString().replace("T", " ").replace(/\.\d{3}Z$/, " UTC");
  return d.toLocaleString(undefined, { dateStyle: "medium", timeStyle: "short" });
}
function fmtInt(n) { return Math.round(num(n)).toLocaleString("en-US"); }
function fmtMoney(n) { return `$${num(n).toFixed(4)}`; }
function humanDuration(sec) {
  sec = Math.max(0, Math.round(sec));
  const d = Math.floor(sec / 86400); sec %= 86400;
  const h = Math.floor(sec / 3600); sec %= 3600;
  const m = Math.floor(sec / 60);
  if (d) return `${d}d ${h}h`;
  if (h) return `${h}h ${m}m`;
  return `${m}m`;
}
function addAgg(agg, r) {
  agg.requests += 1;
  agg.input += num(r.inputTokens);
  agg.cacheRead += num(r.cacheReadTokens);
  agg.cacheWrite += num(r.cacheWrite5mTokens) + num(r.cacheWrite1hTokens);
  agg.totalInput += totalInput(r);
  agg.output += num(r.outputTokens);
  agg.reasoning += num(r.reasoningTokens);
  agg.cost += rowCost(r);
}
function newAgg() { return { requests: 0, input: 0, cacheRead: 0, cacheWrite: 0, totalInput: 0, output: 0, reasoning: 0, cost: 0 }; }
function table(headers, rows, indent = "  ") {
  const widths = headers.map((h, i) => Math.max(String(h).length, ...rows.map(r => String(r[i] ?? "").length)));
  const line = headers.map((h, i) => String(h).padEnd(widths[i])).join("  ");
  const sep = widths.map(w => "─".repeat(w)).join("  ");
  const body = rows.map(r => r.map((c, i) => {
    const s = String(c ?? "");
    return i === 0 ? s.padEnd(widths[i]) : s.padStart(widths[i]);
  }).join("  "));
  return [line, sep, ...body].map(l => indent + l).join("\n");
}
function section(title) {
  console.log(`\n◆ ${title}`);
  console.log("  " + "━".repeat(Math.max(18, title.length + 4)));
}

function summarize(rows, quota, cache) {
  const startAt = dateBoundary(opts.start);
  const endAt = dateBoundary(opts.end, true);
  const startMs = startAt?.getTime() ?? -Infinity;
  const endMs = endAt?.getTime() ?? Infinity;
  const clean = rows
    .map(r => ({ ...r, _date: new Date(r.timeCreated) }))
    .filter(r => Number.isFinite(r._date.getTime()) && r._date.getTime() >= startMs && r._date.getTime() <= endMs);
  clean.sort((a, b) => b._date - a._date);
  const total = newAgg();
  for (const r of clean) addAgg(total, r);

  const byModelMap = new Map();
  const byDayMap = new Map();
  for (const r of clean) {
    const model = r.model || "unknown";
    if (!byModelMap.has(model)) byModelMap.set(model, newAgg());
    addAgg(byModelMap.get(model), r);
    const day = localDateKey(r._date);
    if (!byDayMap.has(day)) byDayMap.set(day, newAgg());
    addAgg(byDayMap.get(day), r);
  }

  const now = new Date();
  const todayKey = localDateKey(now);
  const monthKey = opts.utc
    ? now.toISOString().slice(0, 7)
    : `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}`;
  const last7 = newAgg();
  const today = byDayMap.get(todayKey) || newAgg();
  const month = newAgg();
  const weekCut = Date.now() - 7 * 86400 * 1000;
  for (const r of clean) {
    if (r._date.getTime() >= weekCut) addAgg(last7, r);
    if (localDateKey(r._date).startsWith(monthKey)) addAgg(month, r);
  }

  const byModel = [...byModelMap.entries()].map(([model, a]) => ({ model, ...a })).sort((a, b) => b.cost - a.cost);
  const byDay = [...byDayMap.entries()].map(([day, a]) => ({ day, ...a })).sort((a, b) => b.day.localeCompare(a.day));
  const dateFilter = opts.start || opts.end ? {
    start: opts.start?.value || null,
    end: opts.end?.value || null,
    timezone: opts.utc ? "UTC" : "local",
  } : null;
  return { workspaceId, dateFilter, requests: clean.length, first: clean.at(-1)?._date, last: clean[0]?._date, quota, cache, total, today, last7, month, byModel, byDay, latest: clean.slice(0, opts.latest || 0) };
}

function printSummary(s) {
  console.log(`\nOpenCode usage  │  ${s.workspaceId}`);
  if (s.dateFilter) {
    console.log(`Date filter: ${s.dateFilter.start || "earliest"} → ${s.dateFilter.end || "latest"} (${s.dateFilter.timezone})`);
  }
  console.log(`Requests: ${fmtInt(s.requests)}${s.first && s.last ? `  │  Range: ${fmtDateTime(s.first)} → ${fmtDateTime(s.last)}` : ""}`);
  if (s.cache) {
    console.log(`Cache: ${path.relative(process.cwd(), s.cache.file) || s.cache.file}  │  API pages fetched: ${s.cache.apiPagesFetched}  │  New requests: ${fmtInt(s.cache.newRequests)}`);
  }

  if (s.quota.length) {
    section("Quota / resets");
    console.log(table(["Window", "Used", "Resets in", "Reset time"], s.quota.map(q => [
      `${q.short} ${q.label}`,
      `${q.usagePercent.toFixed(2)}%`,
      humanDuration(q.resetInSec),
      fmtDateTime(q.resetAt),
    ])));
  }

  section("Spend / requests");
  console.log(table(["Period", "Requests", "Input+cache", "Output", "Reasoning", "Cost"], [
    ["Today", fmtInt(s.today.requests), fmtInt(s.today.totalInput), fmtInt(s.today.output), fmtInt(s.today.reasoning), fmtMoney(s.today.cost)],
    ["Last 7d", fmtInt(s.last7.requests), fmtInt(s.last7.totalInput), fmtInt(s.last7.output), fmtInt(s.last7.reasoning), fmtMoney(s.last7.cost)],
    ["This month", fmtInt(s.month.requests), fmtInt(s.month.totalInput), fmtInt(s.month.output), fmtInt(s.month.reasoning), fmtMoney(s.month.cost)],
    [s.dateFilter ? "Selected" : "All time", fmtInt(s.total.requests), fmtInt(s.total.totalInput), fmtInt(s.total.output), fmtInt(s.total.reasoning), fmtMoney(s.total.cost)],
  ]));

  section("By model");
  console.log(table(["Model", "Requests", "Input", "Cache read", "Cache write", "Input+cache", "Output", "Reasoning", "Cost"], s.byModel.map(m => [
    m.model,
    fmtInt(m.requests),
    fmtInt(m.input),
    fmtInt(m.cacheRead),
    fmtInt(m.cacheWrite),
    fmtInt(m.totalInput),
    fmtInt(m.output),
    fmtInt(m.reasoning),
    fmtMoney(m.cost),
  ])));

  section("By day");
  console.log(table(["Day", "Requests", "Input+cache", "Output", "Reasoning", "Cost"], s.byDay.map(d => [
    d.day,
    fmtInt(d.requests),
    fmtInt(d.totalInput),
    fmtInt(d.output),
    fmtInt(d.reasoning),
    fmtMoney(d.cost),
  ])));

  if (opts.latest) {
    section(`Latest ${opts.latest}`);
    console.log(table(["Time", "Model", "Req input", "Cache", "Output", "Reasoning", "Cost", "Session"], s.latest.map(r => [
      fmtDateTime(r._date),
      r.model || "",
      fmtInt(r.inputTokens),
      fmtInt(num(r.cacheReadTokens) + num(r.cacheWrite5mTokens) + num(r.cacheWrite1hTokens)),
      fmtInt(r.outputTokens),
      fmtInt(r.reasoningTokens),
      fmtMoney(rowCost(r)),
      (r.sessionID || "-").slice(-8),
    ])));
  }

  console.log("");
}

(async () => {
  try {
    const [usageHtml, goHtmlResult] = await Promise.all([
      fetchText(usageUrl),
      fetchText(goUrl).catch(e => opts.verbose ? Promise.reject(e) : ""),
    ]);
    const quota = goHtmlResult ? parseQuota(goHtmlResult) : [];
    const { rows, cache } = await fetchUsageWithCache(usageHtml);
    const summary = summarize(rows, quota, cache);
    if (opts.json) {
      const replacer = (k, v) => v instanceof Date ? v.toISOString() : v;
      console.log(JSON.stringify(summary, replacer, 2));
    } else {
      printSummary(summary);
    }
  } catch (e) {
    die(`OPC failed: ${e?.stack || e?.message || e}`);
  }
})();
